{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/dicas", "destination": "/sobre", "permanent": true },
    { "source": "/dicas.html", "destination": "/sobre.html", "permanent": true },
    { "source": "/comunidade", "destination": "/sobre", "permanent": true },
    { "source": "/comunidade.html", "destination": "/sobre.html", "permanent": true },
    { "source": "/exemplos", "destination": "/sobre", "permanent": true },
    { "source": "/exemplos.html", "destination": "/sobre.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/:path(gerador|painel|orcamentos|clientes|veiculos|ordens|ordem|estoque|agenda|relatorios|recorrentes|ver)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/gerador", "destination": "/gerador.html" },
    { "source": "/painel", "destination": "/painel.html" },
    { "source": "/orcamentos", "destination": "/orcamentos.html" },
    { "source": "/clientes", "destination": "/clientes.html" },
    { "source": "/veiculos", "destination": "/veiculos.html" },
    { "source": "/ordens", "destination": "/ordens.html" },
    { "source": "/ordem", "destination": "/ordem.html" },
    { "source": "/agenda", "destination": "/agenda.html" },
    { "source": "/recorrentes", "destination": "/recorrentes.html" },
    { "source": "/estoque", "destination": "/estoque.html" },
    { "source": "/relatorios", "destination": "/relatorios.html" },
    { "source": "/planos", "destination": "/planos.html" },
    { "source": "/sobre", "destination": "/sobre.html" },
    { "source": "/contato", "destination": "/contato.html" },
    { "source": "/privacidade", "destination": "/privacidade.html" },
    { "source": "/termos", "destination": "/termos.html" },
    { "source": "/manual", "destination": "/manual.html" },
    { "source": "/ver", "destination": "/ver.html" }
  ]
}

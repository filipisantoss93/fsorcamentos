{
  "name": "fsorcamentos",
  "version": "1.0.0",
  "description": "FS Orçamentos - plataforma de orçamentos e gestão de oficina.",
  "type": "module",
  "scripts": {
    "check": "node scripts/validate-project.mjs",
    "audit": "node scripts/audit-project.mjs",
    "cleanup:orcamentos:first-style": "node scripts/remove-orcamentos-first-style.mjs",
    "cleanup:orcamentos:named-styles": "node scripts/extract-orcamentos-named-styles.mjs",
    "cleanup:orcamentos:auth-inline": "node scripts/cleanup-orcamentos-auth-inline.mjs",
    "cleanup:orcamentos:head": "node scripts/cleanup-orcamentos-head-residue.mjs",
    "cleanup:gerador:first-style": "node scripts/extract-gerador-first-style.mjs",
    "cleanup:ordem:first-style": "node scripts/extract-ordem-first-style.mjs",
    "cleanup:ordem:named-styles": "node scripts/extract-ordem-named-styles.mjs",
    "cleanup:painel:first-style": "node scripts/extract-painel-first-style.mjs",
    "cleanup:estoque:first-style": "node scripts/extract-estoque-first-style.mjs",
    "cleanup:planos:first-style": "node scripts/extract-planos-first-style.mjs",
    "cleanup:sobre:first-style": "node scripts/extract-sobre-first-style.mjs",
    "cleanup:exemplos:first-style": "node scripts/extract-exemplos-first-style.mjs",
    "cleanup:contato:first-style": "node scripts/extract-contato-first-style.mjs",
    "cleanup:clientes:first-style": "node scripts/extract-clientes-first-style.mjs",
    "cleanup:ordens:first-style": "node scripts/extract-ordens-first-style.mjs",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew bundleRelease"
  },
  "keywords": [
    "orcamentos",
    "oficina",
    "supabase",
    "capacitor"
  ],
  "author": "Filipi Aparecido dos Santos",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@supabase/supabase-js": "^2.106.2"
  },
  "devDependencies": {}
}
